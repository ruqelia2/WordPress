{
    "name": "ruqelia2/wp-datacharts-pro",
    "description": "A powerful chart visualization plugin for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": { "php": ">=8.0" },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": { "psr-4": { "WPDCP\\": "includes/" } },
    "autoload-dev": { "psr-4": { "WPDCP\\Tests\\": "tests/" } },
    "config": { "optimize-autoloader": true, "sort-packages": true },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse includes/ --level=8",
        "phpcs": "phpcs --standard=WordPress includes/"
    }
}
